{
  "name": "immich-frame",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "generate": "python3 scripts/generate_assets.py",
    "check:generated": "python3 scripts/generate_assets.py --check",
    "check:schema": "node scripts/check_product_schema.mjs",
    "check:release-ready": "python3 scripts/check_release_ready.py",
    "check:release-ready-with-compile": "python3 scripts/check_release_ready.py --compile",
    "check:firmware-release": "python3 scripts/check_firmware_release.py",
    "check:firmware-fields": "python3 scripts/check_firmware_fields.py",
    "check:release-changelog": "python3 scripts/check_release_changelog.py",
    "check:backup": "python3 scripts/check_backup_config.py",
    "check:compat": "python3 scripts/check_compatibility.py",
    "check:ownership": "python3 scripts/check_source_ownership.py",
    "check:budgets": "python3 scripts/check_build_budgets.py",
    "check:product": "python3 scripts/check_product_contract.py",
    "changelog:release": "python3 scripts/release_changelog.py",
    "test:web-compat": "node tests/web_compat_tests.js",
    "test:web-modules": "node tests/web_module_tests.js",
    "test:web-smoke-cli": "node tests/web_smoke_cli_tests.js",
    "test:web-smoke": "node tests/web_smoke_tests.js",
    "test:web": "npm run test:web-compat && npm run test:web-modules && npm run test:web-smoke-cli && npm run test:web-smoke",
    "test:package-contract": "python3 tests/package_contract_tests.py",
    "test:product-contract-common": "python3 tests/product_contract_common_tests.py",
    "test:release-ready": "python3 tests/release_ready_tests.py",
    "test:workflow-contract": "python3 tests/workflow_contract_tests.py",
    "test:budgets": "python3 tests/build_budget_tests.py",
    "test:timezones": "python3 scripts/check_timezones.py",
    "test:helpers": "g++ -std=c++17 -I. -Itests/stubs tests/espframe_helper_tests.cpp -o /tmp/espframe_helper_tests && /tmp/espframe_helper_tests",
    "test:firmware-logic": "npm run test:helpers && npm run test:timezones",
    "check:fast": "npm run check:schema && npm run check:generated && npm run check:product && npm run check:backup && npm run check:compat && npm run check:ownership && npm run check:budgets && npm run check:firmware-fields",
    "check:pr": "npm run check:fast && npm run webserver:typecheck && npm run test:web-compat && npm run test:web-modules && npm run test:web-smoke-cli && npm run test:web-smoke && npm run test:package-contract && npm run test:product-contract-common && npm run test:release-ready && npm run test:workflow-contract && npm run test:budgets && npm run test:firmware-logic && npm run docs:build",
    "check:release": "npm run check:pr && npm run check:firmware-release && npm run check:release-changelog",
    "check:all": "npm run check:release",
    "webserver:build": "python3 scripts/generate_assets.py",
    "webserver:typecheck": "tsc --noEmit --strict --target ES2018 --lib ES2018,DOM --skipLibCheck docs/webserver/src/web_contracts.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.28.1",
    "typescript": "^7.0.2",
    "vitepress": "^1.6.3"
  }
}
