    "Chrome",
    "Edge"
  ],
  "web_installer_required_api": "Web Serial",
  "web_installer_computer_requirement": "desktop computer",
  "web_installer_unsupported_browsers": [
    "Safari",
    "Firefox"
  ],
  "usb_cable_requirement": "USB-C data cable",
  "usb_cable_warning": "not a charge-only cable",
  "immich_api_key_mode": "read-only",
  "immich_api_key_privacy_promise": "never modifies or uploads",
  "immich_api_key_permissions": [
    {
      "name": "asset.read",
      "purpose": "Search for random photos and read metadata (date, location, EXIF)"
    },
    {
      "name": "asset.view",
      "purpose": "Download photo thumbnails for display"
    },
    {
      "name": "person.read",
      "purpose": "Show people's names on the photo overlay"
    },
    {
      "name": "album.read",
      "purpose": "Album names a photo belongs to"
    },
    {
      "name": "tag.read",
      "purpose": "Tags assigned to photos"
    },
    {
      "name": "memory.read",
      "purpose": "\"On this day\" memories and groupings"
    },
    {
      "name": "map.read",
      "purpose": "Additional GPS/map data beyond EXIF"
    }
  ],
  "immich_server_url_schemes": [
    "http://",
    "https://"
  ],
  "immich_server_url_targets": [
    "IP address",
    "domain"
  ],
  "immich_server_url_examples": [
    "http://192.168.1.30:2283",
    "https://photos.example.com"
  ],
