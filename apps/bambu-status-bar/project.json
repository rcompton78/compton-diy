{
  "name": "bambu-status-bar",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "build-s3": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run -e s3",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "build-c3": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run -e c3",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "build-pico32": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run -e pico32",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "flash": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run -t upload",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "flash-s3": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run -e s3 -t upload",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "flash-c3": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run -e c3 -t upload",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "monitor": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio device monitor",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "build-fs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 -m platformio run -t buildfs",
        "cwd": "apps/bambu-status-bar"
      }
    },
    "version": {
      "executor": "@compton/nx-version:npm-version",
      "options": {
        "buildTargetName": "build"
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 tools/esp-flasher/generate_release.py --project-dir apps/bambu-status-bar --name \"Bambu Status Bar\" --build c3:ESP32-C3 --build s3:ESP32-S3 --build pico32:ESP32 --version ${RELEASE_VERSION:-dev}",
        "cwd": "."
      },
      "dependsOn": ["build", "build-fs"]
    }
  }
}
