{
  "name": "cyd-clock",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["platform:esp32", "type:firmware"],
  "implicitDependencies": ["weather-client"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/build-boards.sh apps/cyd-clock",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/include/**",
        "{projectRoot}/platformio.ini",
        "{workspaceRoot}/libs/weather-client/src/**"
      ],
      "outputs": ["{projectRoot}/.pio/build/cyd", "{projectRoot}/.pio/build/freenove-s3"]
    },
    "build-cyd": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/pio.sh run -d apps/cyd-clock -e cyd",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/include/**",
        "{projectRoot}/platformio.ini",
        "{workspaceRoot}/libs/weather-client/src/**"
      ],
      "outputs": ["{projectRoot}/.pio/build/cyd"]
    },
    "flash-cyd": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/pio.sh run -d apps/cyd-clock -e cyd -t upload",
        "cwd": "."
      }
    },
    "build-freenove-s3": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/pio.sh run -d apps/cyd-clock -e freenove-s3",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/include/**",
        "{projectRoot}/platformio.ini",
        "{workspaceRoot}/libs/weather-client/src/**"
      ],
      "outputs": ["{projectRoot}/.pio/build/freenove-s3"]
    },
    "flash-freenove-s3": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/pio.sh run -d apps/cyd-clock -e freenove-s3 -t upload",
        "cwd": "."
      }
    },
    "build-fs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/pio.sh run -d apps/cyd-clock -e cyd -t buildfs",
        "cwd": "."
      },
      "cache": true,
      "inputs": ["{projectRoot}/data/**"],
      "outputs": ["{projectRoot}/.pio/build/cyd/littlefs.bin"]
    },
    "flash-fs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/pio.sh run -d apps/cyd-clock -e cyd -t uploadfs",
        "cwd": "."
      }
    },
    "monitor": {
      "executor": "nx:run-commands",
      "options": {
        "command": "scripts/pio.sh device monitor -d apps/cyd-clock",
        "cwd": "."
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "python3 tools/esp-flasher/generate_release.py --project-dir apps/cyd-clock --name \"CYD Clock\" --build cyd:ESP32 --build freenove-s3:ESP32-S3 --version ${RELEASE_VERSION:-dev}",
        "cwd": "."
      },
      "dependsOn": ["build-cyd", "build-freenove-s3", "build-fs"]
    }
  }
}
