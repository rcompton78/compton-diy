# Copy to .env (gitignored) to override build-time flash-sale API settings for local testing,
# without touching platformio.ini or Config.h. Picked up automatically by scripts/pio.sh.
# See DIY-79.

# Point at a local/LAN cat-buddy-api dev instance instead of the real prod endpoint.
# Note the /api prefix — cat-buddy-api sets a global 'api' route prefix.
CAT_BUDDY_API_URL=http://192.168.1.50:8013/api/flash-sale/current

# Must match the dev token cat-buddy-api's local docker-compose-dev.yml / .env is using.
CAT_BUDDY_API_TOKEN=dev-local-token
